# ════════════════════════════════════════════════════════
# Thamy Shoes — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env
# ════════════════════════════════════════════════════════

# ── Database (Supabase PostgreSQL) ──────────────────────
# Connection pooler URL (para queries normais)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (para migrations — sem pooling)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# ── Auth (JWT) ───────────────────────────────────────────
# Segredo JWT — mínimo 32 caracteres aleatórios
# Gerar com: openssl rand -base64 48
JWT_SECRET="sua-chave-jwt-aqui-minimo-32-chars"

# Expiração do token JWT (padrão: 8h)
JWT_EXPIRES_IN="8h"

# ── Bling OAuth ──────────────────────────────────────────
# Credenciais do app no portal Bling
BLING_CLIENT_ID="seu-bling-client-id"
BLING_CLIENT_SECRET="seu-bling-client-secret"
BLING_REDIRECT_URI="https://seu-dominio.vercel.app/api/bling/callback"

# Chave de criptografia AES-256-GCM para tokens Bling
# Deve ter EXATAMENTE 32 bytes em hex (64 caracteres hex)
# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY="sua-chave-de-criptografia-32-bytes-hex-aqui-64chars"

# ── Supabase Storage ─────────────────────────────────────
# URL do projeto Supabase
SUPABASE_URL="https://[PROJECT-REF].supabase.co"

# Service Role Key (acesso admin ao Storage — NÃO expor no cliente)
SUPABASE_SERVICE_KEY="seu-supabase-service-role-key"

# ── Aplicação ─────────────────────────────────────────────
# URL pública da aplicação (sem trailing slash)
NEXT_PUBLIC_APP_URL="https://seu-dominio.vercel.app"

# ── Notificações (Resend) ────────────────────────────────
RESEND_API_KEY="re_sua-chave-resend"

# Email destinatário dos alertas de token Bling
NOTIFICATION_EMAIL_TO="admin@thamyshoes.com.br"

# ── Usuário Admin Inicial ────────────────────────────────
# Email do admin criado pelo seed
ADMIN_EMAIL="admin@thamyshoes.com.br"

# ── Vercel Cron ──────────────────────────────────────────
# Segredo para autenticar chamadas do Vercel Cron
# Gerar com: openssl rand -base64 24
CRON_SECRET="seu-cron-secret-minimo-16-chars"

# ── Ambiente ──────────────────────────────────────────────
NODE_ENV="development"
SKIP_ENV_VALIDATION="1"
